table fct_daily_cash_position
	lineageTag: 71986c96-f540-4a4d-b333-b248dec5f4d5

	measure 'Total Expected Settlement' = SUM(fct_daily_cash_position[total_expected_settlement_amount])
		formatString: \$#,0.00
		lineageTag: 855e5a7d-3b9b-4aff-bd2f-e909347c9e52

	measure 'Total Actual Cash Received' = SUM(fct_daily_cash_position[total_actual_cash_received])
		formatString: \$#,0.00
		lineageTag: 31345c49-4791-4dfd-8983-21edc8318c0f

	measure 'Reconciliation Match Rate' = DIVIDE(
		    SUMX(fct_daily_cash_position, fct_daily_cash_position[reconciliation_match_rate] * fct_daily_cash_position[total_expected_settlement_amount]),
		    SUM(fct_daily_cash_position[total_expected_settlement_amount])
		)
		formatString: 0.00%
		lineageTag: 6180c225-47f8-446c-8116-aaecad5f89f4

	measure 'Unresolved Break Amount (Latest Day)' = VAR LatestDate = MAX(fct_daily_cash_position[batch_date])
		RETURN
		    CALCULATE(
		        SUM(fct_daily_cash_position[unresolved_break_amount]),
		        fct_daily_cash_position[batch_date] = LatestDate
		    )
		formatString: \$#,0.00
		lineageTag: debadd02-f7dd-430a-a5c6-936f00785b37

	measure 'Break Rate (Dollar Basis)' = DIVIDE([Total Expected Settlement] - [Total Actual Cash Received], [Total Expected Settlement])
		formatString: 0.00%
		lineageTag: d3ba6c1e-f9c7-474c-9ac9-2f8145f276ef

	column batch_date
		dataType: dateTime
		isKey: true
		formatString: Long Date
		sourceColumn: batch_date
		lineageTag: 141ea72e-8df8-4294-a661-d830bee9a2ff

		annotation SummarizationSetBy = Automatic

	column settlement_batch_count
		dataType: int64
		sourceColumn: settlement_batch_count
		lineageTag: 92fd0c20-f475-4ba2-88e8-7e6cabce3ac1

		annotation SummarizationSetBy = Automatic

	column matched_batch_count
