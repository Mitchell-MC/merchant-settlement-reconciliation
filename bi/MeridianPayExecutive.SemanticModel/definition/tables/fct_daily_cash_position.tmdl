		sourceColumn: matched_batch_count
		lineageTag: 6f48b93f-6b60-41d9-b207-49dff349db95

		annotation SummarizationSetBy = Automatic

	column break_count
		dataType: int64
		sourceColumn: break_count
		lineageTag: 7a72a209-b09b-4da6-a5b4-4903099542ca

		annotation SummarizationSetBy = Automatic

	column total_expected_settlement_amount
