model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["fct_daily_cash_position", "fct_reconciliation_breaks", "fct_funding_cost_summary", "fct_merchant_exception_trends", "vw_exception_queue_masked", "dim_merchant", "dim_date"]

annotation __PBI_TimeIntelligenceEnabled = 0

ref table fct_daily_cash_position
ref table fct_reconciliation_breaks
ref table fct_funding_cost_summary
ref table fct_merchant_exception_trends
ref table vw_exception_queue_masked
ref table dim_merchant
ref table dim_date

ref cultureInfo en-US
